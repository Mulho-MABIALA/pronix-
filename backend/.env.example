# ─── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/statistique_foot"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="votre_secret_access_jwt_tres_long_et_aleatoire"
JWT_REFRESH_SECRET="votre_secret_refresh_jwt_tres_long_et_aleatoire"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ─── API Football (API-Football via RapidAPI) ──────────────────────────────────
FOOTBALL_API_KEY="votre_cle_api_rapidapi"
FOOTBALL_API_HOST="api-football-v1.p.rapidapi.com"
FOOTBALL_API_BASE_URL="https://api-football-v1.p.rapidapi.com/v3"

# ─── Wave (paiement mobile Sénégal) ───────────────────────────────────────────
WAVE_API_KEY="votre_cle_api_wave"
WAVE_BASE_URL="https://api.wave.com/v1"
WAVE_WEBHOOK_SECRET="votre_secret_webhook_wave"

# ─── CinetPay (carte bancaire Visa/Mastercard + Wave agrégateur) ───────────────
CINETPAY_API_KEY="votre_cle_api_cinetpay"
CINETPAY_SITE_ID="votre_site_id_cinetpay"
CINETPAY_BASE_URL="https://api-checkout.cinetpay.com/v2"
CINETPAY_NOTIFY_URL="https://votre-domaine.com/api/payments/cinetpay/webhook"
CINETPAY_RETURN_URL="https://votre-domaine.com/abonnement/confirmation"

# ─── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="votre_email@gmail.com"
SMTP_PASS="votre_mot_de_passe_application"
EMAIL_FROM="Statistique Foot <noreply@statistiquefoot.sn>"

# ─── Notifications SMS/WhatsApp (optionnel — ex. Twilio) ──────────────────────
TWILIO_ACCOUNT_SID="votre_account_sid"
TWILIO_AUTH_TOKEN="votre_auth_token"
TWILIO_PHONE_NUMBER="+12345678901"

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Statistique Foot"
APP_URL="https://statistiquefoot.sn"
BCRYPT_ROUNDS=12
