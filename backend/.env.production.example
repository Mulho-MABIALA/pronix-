# ══════════════════════════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — PRODUCTION
# Copier ce fichier en .env sur le serveur Hetzner
# Remplir TOUTES les valeurs avant de démarrer l'application
# ══════════════════════════════════════════════════════════════════

# ─── Base de données ───────────────────────────────────────────────
DATABASE_URL="postgresql://statfoot:CHANGE_MOI_MOT_DE_PASSE_FORT@localhost:5432/statfoot_prod"

# ─── JWT — GÉNÉRER DES SECRETS FORTS ──────────────────────────────
# Génère ces valeurs avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="GENERER_UN_SECRET_64_CHARS_MINIMUM_ICI"
JWT_REFRESH_SECRET="GENERER_UN_AUTRE_SECRET_64_CHARS_MINIMUM_ICI"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Serveur ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV="production"
FRONTEND_URL="https://www.VOTRE_DOMAINE.com"

# ─── API Football ─────────────────────────────────────────────────
FOOTBALL_API_KEY="VOTRE_CLE_RAPIDAPI"
FOOTBALL_API_HOST="free-api-live-football-data.p.rapidapi.com"
FOOTBALL_API_BASE_URL="https://free-api-live-football-data.p.rapidapi.com"

# ─── FedaPay ──────────────────────────────────────────────────────
# Récupérer sur : https://app.fedapay.com/settings/api
FEDAPAY_SECRET_KEY="sk_live_VOTRE_CLE_FEDAPAY"
FEDAPAY_WEBHOOK_SECRET="VOTRE_WEBHOOK_SECRET_FEDAPAY"

# ─── Wave (optionnel si tu utilises FedaPay) ──────────────────────
WAVE_API_KEY=""
WAVE_BASE_URL="https://api.wave.com/v1"
WAVE_WEBHOOK_SECRET=""

# ─── Email (Gmail avec mot de passe d'application) ────────────────
# Créer un mot de passe d'application Gmail :
# Google Account → Sécurité → Mots de passe des applications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="TON_EMAIL@gmail.com"
SMTP_PASS="XXXX XXXX XXXX XXXX"
EMAIL_FROM="StatFoot <noreply@VOTRE_DOMAINE.com>"

# ─── Application ──────────────────────────────────────────────────
APP_NAME="StatFoot"
BCRYPT_ROUNDS=12

# ─── Web Push / Notifications (VAPID) ─────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="VOTRE_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="VOTRE_VAPID_PRIVATE_KEY"
